rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() { return request.auth != null; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    
    function isValidMatch(data) {
      return data.keys().hasAll(['status', 'players', 'isBotMatch', 'scores', 'choices', 'createdAt', 'updatedAt'])
             && data.status in ['waiting', 'playing', 'completed', 'abandoned', 'result']
             && data.players is list
             && data.players.size() >= 1 && data.players.size() <= 3
             && data.isBotMatch is bool
             && data.createdAt is timestamp
             && data.updatedAt is timestamp;
    }

    match /matches/{matchId} {
      allow get: if isSignedIn() && (
        resource == null || resource.data.status == 'waiting' || request.auth.uid in resource.data.players
      );
      
      allow list: if isSignedIn() && resource.data.status == 'waiting';
      
      allow create: if isSignedIn() 
                    && isValidMatch(incoming()) 
                    && request.auth.uid in incoming().players
                    && incoming().createdAt == request.time
                    && incoming().updatedAt == request.time;
                    
      allow update: if isSignedIn() 
                    && (request.auth.uid in existing().players || request.auth.uid in incoming().players)
                    && isValidMatch(incoming())
                    && incoming().createdAt == existing().createdAt
                    && incoming().updatedAt == request.time;
    }
  }
}
